# ─────────────────────────────────────────────────────────────
# SEA — Synthetic Evidence Analyzer — .gitignore
# ─────────────────────────────────────────────────────────────

# Environment & secrets — NEVER commit API keys
.env
*.env.local
*.env.production

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Uploaded evidence files (local only — not for source control)
backend/uploads/*
!backend/uploads/.gitkeep

# Generated forensic reports (local output)
reports/*.md
!reports/.gitkeep

# OS artifacts
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
dist/
build/
